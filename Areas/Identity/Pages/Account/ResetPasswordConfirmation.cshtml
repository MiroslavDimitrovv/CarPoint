@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Паролата е обновена";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-7 col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 text-center">
                    <h1 class="h3 mb-3">@ViewData["Title"]</h1>
                    <p class="text-muted mb-3">Паролата ти беше сменена успешно.</p>
                    <a asp-page="./Login" class="btn btn-primary">Към вход</a>
                </div>
            </div>
        </div>
    </div>
</div>
