@model CarPoint.Models.ViewModels.SalesIndexVm
@{
    ViewData["Title"] = "Каталог";
}

<section class="catalog-header">
    <div>
        <span class="section-label">Покупка</span>
        <h1>Автомобили за продажба</h1>
        <p>Разгледай наличните предложения и филтрирай според бюджета и предпочитанията си.</p>
    </div>
    <div class="catalog-summary">
        <strong>@Model.Cars.Count</strong>
        <span>налични предложения</span>
        <button class="btn btn-brand-outline d-md-none mt-3" type="button" data-bs-toggle="offcanvas" data-bs-target="#filtersCanvasSale">Филтри</button>
    </div>
</section>

<section class="catalog-layout">
    <aside class="catalog-sidebar d-none d-md-block">
        <div class="sidebar-card">
            <h2>Филтри</h2>
            @await Html.PartialAsync("_CarFiltersSale", Model.Filter)
        </div>
    </aside>

    <div class="catalog-content">
        <div class="listing-grid">
            @foreach (var c in Model.Cars)
            {
                <article class="car-card">
                    <img src="~/images/cars/@(c.ImageFileName ?? "placeholder.jpg")" alt="@c.Brand @c.Model" class="car-card-image" />
                    <div class="car-card-body">
                        <div class="car-card-top">
                            <div>
                                <h2>@c.Brand @c.Model</h2>
                                <p>@c.Year • @c.Mileage km • @c.FuelType</p>
                            </div>
                            <strong class="price-badge">@((c.SalePrice ?? 0).ToString("0")) €</strong>
                        </div>
                        <div class="spec-row">
                            <span>@c.Engine</span>
                            <span>@c.HorsePower hp</span>
                            <span>@c.Transmission</span>
                        </div>
                        <div class="card-actions">
                            <a class="btn btn-brand w-100" asp-controller="Sales" asp-action="Details" asp-route-id="@c.Id">Виж детайли</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a class="btn btn-brand-outline" asp-controller="AdminCars" asp-action="Edit" asp-route-id="@c.Id">Редакция</a>
                            }
                        </div>
                    </div>
                </article>
            }
        </div>

        @if (Model.Cars.Count == 0)
        {
            <div class="empty-state">
                <h3>Няма резултати</h3>
                <p>Промени филтрите и опитай отново.</p>
            </div>
        }
    </div>
</section>

<div class="offcanvas offcanvas-end" tabindex="-1" id="filtersCanvasSale">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title">Филтри</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body">
        <div class="sidebar-card">
            <h2>Филтри</h2>
            @await Html.PartialAsync("_CarFiltersSale", Model.Filter)
        </div>
    </div>
</div>
