@model IEnumerable<CarPoint.Models.ViewModels.Support.SupportTicketRowVm>

@{
    ViewData["Title"] = "Моите заявки";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4 m-0">Моите заявки</h1>
        <a class="btn btn-primary" asp-controller="Support" asp-action="Create">Нова заявка</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-light border">Все още нямаш изпратени заявки.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Дата</th>
                        <th>Тема</th>
                        <th>Категория</th>
                        <th>Приоритет</th>
                        <th>Статус</th>
                        <th>Отговор</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ticket in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@ticket.Id</td>
                            <td>@(ticket.CreatedAt.ToString("dd.MM.yyyy HH:mm"))</td>
                            <td>
                                <a asp-controller="Support" asp-action="Details" asp-route-id="@ticket.Id">@ticket.Subject</a>
                            </td>
                            <td>@Html.DisplayFor(_ => ticket.Category)</td>
                            <td>@Html.DisplayFor(_ => ticket.Priority)</td>
                            <td>@Html.DisplayFor(_ => ticket.Status)</td>
                            <td>
                                @if (ticket.HasUnreadReply)
                                {
                                    <span class="badge bg-danger">Нов отговор</span>
                                }
                                else
                                {
                                    <span class="text-muted small">Няма ново</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
