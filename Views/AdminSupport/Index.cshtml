@using CarPoint.Models
@{
    ViewData["Title"] = "Поддръжка - админ";
    var q = (string)(ViewBag.Q ?? "");
    TicketStatus? status = ViewBag.Status as TicketStatus?;
    var rows = Model as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4 m-0">Заявки за поддръжка</h1>
        <a class="btn btn-outline-secondary" asp-controller="AdminCars" asp-action="Index">Назад към админ панела</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <form method="get" class="row g-2 align-items-end mb-3">
        <div class="col-12 col-md-6">
            <label class="form-label">Търсене</label>
            <input class="form-control" name="q" value="@q" placeholder="тема, имейл, име, телефон..." />
        </div>

        <div class="col-12 col-md-3">
            <label class="form-label">Статус</label>
            <select class="form-select" name="status">
                <option value="">Всички</option>
                <option value="Open" selected="@(status == TicketStatus.Open)">Отворена</option>
                <option value="InProgress" selected="@(status == TicketStatus.InProgress)">В процес</option>
                <option value="Closed" selected="@(status == TicketStatus.Closed)">Затворена</option>
            </select>
        </div>

        <div class="col-12 col-md-3 d-flex gap-2">
            <button class="btn btn-primary w-100" type="submit">Търси</button>
            <a class="btn btn-outline-secondary w-100" asp-action="Index">Изчисти</a>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Дата</th>
                    <th>Тема</th>
                    <th>Подател</th>
                    <th>Статус</th>
                    <th>Приоритет</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in rows)
                {
                    <tr>
                        <td class="fw-semibold">@row.Id</td>
                        <td>@((DateTime)row.CreatedAt).ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <div class="fw-semibold">@row.Subject</div>
                            <div class="text-muted small">@row.Category</div>
                        </td>
                        <td>
                            <div class="fw-semibold">@row.Email</div>
                            <div class="text-muted small">@((string?)row.FullName ?? "(без име)")</div>
                            <div class="text-muted small">@((string?)row.Phone ?? "(няма телефон)")</div>
                        </td>
                        <td>@row.Status</td>
                        <td>@row.Priority</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@row.Id">Отвори</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
