<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CarPoint</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CarPoint.styles.css" asp-append-version="true" />
</head>
@inject CarPoint.Services.SupportNotifications.ISupportNotificationService SupportNotifications
<body>
    @{
        var unreadSupportCount = (User.Identity?.IsAuthenticated ?? false)
            ? await SupportNotifications.GetUnreadCountAsync(User)
            : 0;
    }
    <div class="shell">
        <header class="site-header">
            <div class="container">
                @if (!(User.Identity?.IsAuthenticated ?? false))
                {
                    <div class="guest-banner" id="guestSupportPopup">
                        <div class="guest-banner-copy">
                            <span class="badge-soft">CarPoint</span>
                            <p>Имаш въпрос за автомобил, наем или оценка? Изпрати заявка и екипът ни ще ти отговори.</p>
                        </div>
                        <div class="guest-banner-actions">
                            <a class="btn btn-brand" asp-controller="Support" asp-action="Create">Поддръжка</a>
                            <button type="button" class="guest-banner-close" id="guestSupportPopupClose" aria-label="Затвори">×</button>
                        </div>
                    </div>
                }

                <nav class="navbar navbar-expand-lg site-nav">
                    <div class="container-fluid px-0 nav-shell">
                        <a class="navbar-brand site-brand" asp-area="" asp-controller="Home" asp-action="Index">
                            <span class="brand-mark" aria-hidden="true">🚗</span>
                            <span class="brand-copy">
                                <strong>CarPoint</strong>
                                <small>Покупка, наем и оценка на автомобили</small>
                            </span>
                        </a>

                        <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Отвори менюто">
                            <span class="navbar-toggler-icon"></span>
                        </button>

                        <div class="collapse navbar-collapse" id="mainNavbar">
                            <ul class="navbar-nav nav-links">
                                <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Начало</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Sales" asp-action="Index">Каталог</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="RentalsCatalog" asp-action="Index">Наеми</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="CarValuation" asp-action="Index">Оценка</a></li>
                            </ul>

                            <ul class="navbar-nav nav-actions">
                                @if (User.Identity?.IsAuthenticated ?? false)
                                {
                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle nav-user" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            @User.Identity!.Name
                                            @if (unreadSupportCount > 0)
                                            {
                                                <span class="support-badge">@unreadSupportCount</span>
                                            }
                                        </a>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                            <li><a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">Профил</a></li>
                                            <li><a class="dropdown-item" asp-controller="Rentals" asp-action="My">Моите наеми</a></li>
                                            <li><a class="dropdown-item" asp-controller="Favorites" asp-action="Index">Любими</a></li>
                                            <li>
                                                <a class="dropdown-item d-flex justify-content-between align-items-center" asp-controller="Support" asp-action="My">
                                                    <span>Моите заявки</span>
                                                    @if (unreadSupportCount > 0)
                                                    {
                                                        <span class="support-badge">@unreadSupportCount</span>
                                                    }
                                                </a>
                                            </li>
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <li><a class="dropdown-item" asp-controller="AdminCars" asp-action="Index">Админ панел</a></li>
                                                <li><a class="dropdown-item" asp-controller="AdminSupport" asp-action="Index">Заявки за поддръжка</a></li>
                                            }
                                            <li><hr class="dropdown-divider" /></li>
                                            <li>
                                                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="dropdown-item">Изход</button>
                                                </form>
                                            </li>
                                        </ul>
                                    </li>
                                }
                                else
                                {
                                    <li class="nav-item"><a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Вход</a></li>
                                    <li class="nav-item"><a class="btn btn-brand-outline" asp-area="Identity" asp-page="/Account/Register">Регистрация</a></li>
                                }
                            </ul>
                        </div>
                    </div>
                </nav>
            </div>
        </header>

        <main class="page-shell">
            <div class="container">
                @RenderBody()
            </div>
        </main>

        <footer class="site-footer">
            <div class="container footer-grid">
                <div class="footer-meta">
                    <span>&copy; @DateTime.Now.Year CarPoint</span>
                    <div class="footer-links">
                        <a asp-controller="Home" asp-action="Terms">Условия за използване</a>
                        <a asp-controller="Home" asp-action="Privacy">Лични данни</a>
                    </div>
                </div>
                <a class="btn btn-brand footer-support" asp-controller="Support" asp-action="Create">Поддръжка</a>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    @await Html.PartialAsync("_ContactModal")
</body>
</html>
