@model CarPoint.Models.ViewModels.CarValuationVm

@{
    ViewData["Title"] = "Оценка";
}

<section class="valuation-page">
    <div class="catalog-header">
        <div>
            <span class="section-label">Оценка</span>
            <h1>Оцени автомобила си</h1>
            <p>Попълни основните данни и получи ориентировъчна пазарна стойност.</p>
        </div>
    </div>

    <div class="valuation-layout">
        <aside class="valuation-info">
            <h2>Какво е важно</h2>
            <ul>
                <li>Марка, модел и година на производство</li>
                <li>Пробег, гориво, двигател и трансмисия</li>
                <li>Общо състояние, удари и брой собственици</li>
            </ul>
            <p>Резултатът е ориентировъчен и е подходящ за първоначална преценка преди продажба, покупка или оглед.</p>

            <div class="valuation-info-actions">
                <button type="button" class="btn btn-brand-outline w-100" data-bs-toggle="modal" data-bs-target="#conditionInfoModal">
                    Какво означава състоянието
                </button>
                <button type="button" class="btn btn-brand-outline w-100" data-bs-toggle="modal" data-bs-target="#calculationInfoModal">
                    Как се изчислява оценката
                </button>
            </div>
        </aside>

        <div class="valuation-form-wrap">
            <form id="valuationForm" asp-area="" asp-controller="CarValuation" asp-action="Index" method="post" autocomplete="off" novalidate class="row g-3">
                @Html.AntiForgeryToken()
                <input type="text" name="fake-user" autocomplete="username" class="d-none" />
                <input type="password" name="fake-pass" autocomplete="new-password" class="d-none" />

                <div class="col-md-6">
                    <label class="form-label">Марка</label>
                    <input asp-for="Brand" class="form-control" />
                    <span asp-validation-for="Brand" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Модел</label>
                    <input asp-for="Model" class="form-control" />
                    <span asp-validation-for="Model" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Година</label>
                    <input asp-for="Year" type="number" min="1990" max="2100" class="form-control" />
                    <span asp-validation-for="Year" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Километраж</label>
                    <input asp-for="Mileage" type="number" min="0" class="form-control" />
                    <span asp-validation-for="Mileage" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Гориво</label>
                    <select asp-for="FuelType" class="form-select">
                        <option value="">Избери</option>
                        <option value="Petrol">Бензин</option>
                        <option value="Diesel">Дизел</option>
                        <option value="Hybrid">Хибрид</option>
                        <option value="Electric">Електрически</option>
                    </select>
                    <span asp-validation-for="FuelType" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Скоростна кутия</label>
                    <select asp-for="Transmission" class="form-select">
                        <option value="">Избери</option>
                        <option value="Manual">Ръчна</option>
                        <option value="Automatic">Автоматична</option>
                    </select>
                    <span asp-validation-for="Transmission" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Двигател</label>
                    <input asp-for="Engine" class="form-control" placeholder="Например 2.0 TSI" />
                    <span asp-validation-for="Engine" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Мощност</label>
                    <input asp-for="HorsePower" type="number" min="30" class="form-control" />
                    <span asp-validation-for="HorsePower" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Тип купе</label>
                    <select asp-for="BodyType" class="form-select">
                        <option value="">Избери</option>
                        <option value="Sedan">Седан</option>
                        <option value="Hatchback">Хечбек</option>
                        <option value="Wagon">Комби</option>
                        <option value="SUV">SUV</option>
                        <option value="Coupe">Купе</option>
                        <option value="Convertible">Кабриолет</option>
                    </select>
                    <span asp-validation-for="BodyType" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Състояние</label>
                    <select asp-for="Condition" class="form-select">
                        <option value="Excellent">Отлично</option>
                        <option value="Good">Добро</option>
                        <option value="Average">Средно</option>
                        <option value="Poor">Лошо</option>
                    </select>
                    <span asp-validation-for="Condition" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Катастрофирал</label>
                    <select asp-for="HadAccident" class="form-select">
                        <option value="false">Не</option>
                        <option value="true">Да</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Собственици</label>
                    <input asp-for="OwnersCount" type="number" min="1" max="10" class="form-control" />
                    <span asp-validation-for="OwnersCount" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <button id="submitBtn" type="submit" class="btn btn-brand">Изчисли оценка</button>
                </div>
            </form>

            <div id="loadingBox" class="alert alert-info mt-4 d-none">Изчисляваме ориентировъчната стойност. Моля, изчакай.</div>

            @if (!string.IsNullOrWhiteSpace(Model?.ErrorMessage))
            {
                <div class="alert alert-warning mt-4">@Model.ErrorMessage</div>
            }

            @if (Model?.IsCalculated == true)
            {
                <div class="valuation-result mt-4">
                    <span class="section-label">Резултат</span>
                    <h2>Очаквана пазарна стойност</h2>
                    <div class="valuation-price">@Model.EstimatedPrice @Model.Currency</div>
                </div>
            }
        </div>
    </div>
</section>

<div class="modal fade" id="conditionInfoModal" tabindex="-1" aria-labelledby="conditionInfoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content contact-modal">
            <div class="modal-header border-0">
                <h5 class="modal-title" id="conditionInfoModalLabel">Какво означава състоянието</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Затвори"></button>
            </div>
            <div class="modal-body">
                <p><strong>Отлично</strong> - много запазен автомобил без сериозни забележки, с добър външен вид и поддържан интериор.</p>
                <p><strong>Добро</strong> - нормални следи от употреба, без сериозни технически проблеми или належащи ремонти.</p>
                <p><strong>Средно</strong> - има видимо износване, дребни забележки или нужда от обслужване, но автомобилът е използваем.</p>
                <p class="mb-0"><strong>Лошо</strong> - сериозни външни или технически проблеми, нужда от ремонт или по-сериозна намеса.</p>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="calculationInfoModal" tabindex="-1" aria-labelledby="calculationInfoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content contact-modal">
            <div class="modal-header border-0">
                <h5 class="modal-title" id="calculationInfoModalLabel">Как се изчислява оценката</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Затвори"></button>
            </div>
            <div class="modal-body">
                <p>Оценката се базира на сравними автомобили със сходни данни като марка, модел, година и пробег.</p>
                <p>Системата взема пазарни обяви за подобни автомобили и изчислява ориентировъчна средна стойност.</p>
                <p class="mb-0">След това резултатът се коригира според избраното състояние и дали автомобилът е имал катастрофа.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const form = document.getElementById('valuationForm');
            const loadingBox = document.getElementById('loadingBox');
            const submitBtn = document.getElementById('submitBtn');

            form.addEventListener('submit', function () {
                loadingBox.classList.remove('d-none');
                submitBtn.disabled = true;
                submitBtn.textContent = 'Проверка...';
            });

            form.addEventListener('input', function () {
                loadingBox.classList.add('d-none');
                submitBtn.disabled = false;
                submitBtn.textContent = 'Изчисли оценка';
            });
        })();
    </script>
}
